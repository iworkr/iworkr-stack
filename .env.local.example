# ============================================================
# iWorkr — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── Site Configuration ──
NEXT_PUBLIC_SITE_URL=https://iworkrapp.com
NEXT_PUBLIC_SITE_NAME=iWorkr
NEXT_PUBLIC_APP_URL=https://iworkrapp.com

# ── Supabase ──
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── Polar.sh (Billing / Merchant of Record) ──
# Get from: https://dashboard.polar.sh/settings
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_WEBHOOK_SECRET=whsec_xxx
POLAR_ORGANIZATION_ID=your-polar-org-id
POLAR_SUCCESS_URL=https://your-domain.com/dashboard?checkout=success&checkout_id={CHECKOUT_ID}

# ── Stripe (Billing / Payments / Connect / Terminal) ──
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs for subscription billing
# Create products and prices in Stripe Dashboard, then paste IDs here
NEXT_PUBLIC_STRIPE_PRICE_STARTER_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_STARTER_YEARLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS_YEARLY=price_xxx

# ── Email (Resend) ──
# Get from: https://resend.com/api-keys
ADMIN_EMAIL=admin@yourdomain.com
RESEND_API_KEY=re_xxx

# ── Google Maps ──
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Directions API, Places API, Geocoding API
# Restrict by HTTP referrer (e.g. https://app.iworkr.com/*, http://localhost:3000/*)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# ── OpenAI (AI Agent + Insights) ──
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx

# ── OAuth Encryption ──
# Used to encrypt OAuth tokens at rest (AES-256-GCM). Defaults to SUPABASE_SERVICE_ROLE_KEY.
# OAUTH_ENCRYPTION_KEY=your-strong-secret-key
# OAUTH_STATE_SECRET=your-csrf-state-secret

# ── Xero (Accounting) ──
# Get from: https://developer.xero.com/app/manage
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
# XERO_WEBHOOK_KEY=your-xero-webhook-key

# ── QuickBooks Online (Accounting) ──
# Get from: https://developer.intuit.com/app/developer/qbo/docs/develop
QUICKBOOKS_CLIENT_ID=your-qbo-client-id
QUICKBOOKS_CLIENT_SECRET=your-qbo-client-secret

# ── Google OAuth (Calendar, Drive) ──
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Google Calendar API, Google Drive API, Gmail API (if needed)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── GoHighLevel (CRM / Marketing) ──
# Get from: https://marketplace.gohighlevel.com/
GHL_CLIENT_ID=your-ghl-client-id
GHL_CLIENT_SECRET=your-ghl-client-secret

# ── Microsoft (Outlook, OneDrive) ──
# Get from: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# MICROSOFT_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ── Slack ──
# Get from: https://api.slack.com/apps
# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret

# ── Qase (Test Reporting) ──
# Get from: https://app.qase.io/user/api/token
# Project code: IWORKR. Set QASE_MODE=testops to report to Qase
QASE_API_TOKEN=your-qase-api-token
QASE_TESTOPS_PROJECT=IWORKR

# ── RevenueCat (Mobile Subscriptions) ──
# Configure in flutter/lib/core/services/revenuecat_service.dart
# REVENUECAT_API_KEY=your-revenuecat-key

# ── Sentry (Desktop Error Tracking) ──
# Configure in electron/src/main/main.ts
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Rate Limiting (Upstash Redis) ──
# Required for production rate limiting middleware (login, API, webhooks).
# Without these, rate limiting falls back to in-memory (ineffective on serverless).
# Get from: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Edge Function Security ──
# The explicit domain allowed to communicate with Supabase Edge Functions via CORS.
# Used by supabase/functions/_shared/cors.ts — defaults to https://app.iworkr.com
ALLOWED_ORIGIN="https://app.iworkr.com"

# ── ClickSend (SMS — Project Outrider-Pulse) ──
# Primary SMS provider for live dispatch tracking notifications.
# Get from: https://dashboard.clicksend.com/account/subaccounts
CLICKSEND_USERNAME=your-clicksend-username
CLICKSEND_API_KEY=your-clicksend-api-key
CLICKSEND_SENDER_ID=iWorkr

# ── Mapbox (Live Tracking Map) ──
# Get from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-token
# Mapbox server-side secret key for Edge Functions (Optimization API)
MAPBOX_SECRET_KEY=your-mapbox-secret-key

# ── GoHighLevel Webhook ──
# Required to cryptographically verify incoming GHL webhook signatures (HMAC SHA-256).
# Without this, the GHL webhook route will reject all requests with a 500 error.
# Get from: GoHighLevel Marketplace → Your App → Webhook Settings
GHL_WEBHOOK_SECRET=

# ── OpenWeatherMap (Dynamic Yield Weather Data) ──
# OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
