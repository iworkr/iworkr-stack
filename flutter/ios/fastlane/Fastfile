default_platform(:ios)
require "shellwords"

platform :ios do
  # ──────────────────────────────────────────────────────────────────
  # Lane: setup_app
  # Creates the App ID + App Store Connect entry if it doesn't exist.
  # Usage: fastlane ios setup_app
  # ──────────────────────────────────────────────────────────────────
  desc "Create app on App Store Connect via API (bundle ID + app record)"
  lane :setup_app_api do
    create_app_api(
      app_name: "iWorkr",
      bundle_id: "com.iworkr.app",
      sku: "com.iworkr.app.ios"
    )
  end

  desc "Register the app on Apple Developer Portal and App Store Connect"
  lane :setup_app do
    ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"] = ENV["ASC_KEY_ID"]
    ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"] = ENV["ASC_ISSUER_ID"]
    ENV["APP_STORE_CONNECT_API_KEY_KEY_CONTENT"] = ENV["ASC_KEY_CONTENT"]
    ENV["APP_STORE_CONNECT_API_KEY_IS_KEY_CONTENT_BASE64"] = "true"

    produce(
      app_identifier: "com.iworkr.app",
      app_name: "iWorkr",
      language: "English",
      app_version: "1.0.0",
      sku: "com.iworkr.app.ios",
      platform: "ios"
    )
  end

  # ──────────────────────────────────────────────────────────────────
  # Lane: deploy_ios
  # Builds the Flutter app (including Widget Extension), increments
  # the build number, and uploads the binary to TestFlight.
  # Usage: fastlane ios deploy_ios
  # ──────────────────────────────────────────────────────────────────
  desc "Build and upload to TestFlight"
  lane :deploy_ios do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )

    # 1. Always build Flutter with explicit release target + dart defines.
    #    This prevents stale test targets (integration_test/test_bundle.dart)
    #    or missing Supabase config from leaking into TestFlight releases.
    # Supabase production defaults are baked into supabase_service.dart.
    # dart_defines.env is OPTIONAL — only needed to override (e.g. local dev).
    # Priority: dart_defines.env > env vars > production defaults (always works).
    dart_defines_file = File.expand_path("../../dart_defines.env", __dir__)
    flutter_build_env_prefix = "env -u BUNDLE_GEMFILE -u BUNDLE_BIN_PATH -u RUBYOPT -u RUBYLIB"
    if ENV["SKIP_FLUTTER_BUILD"] == "1"
      UI.important("SKIP_FLUTTER_BUILD=1 set: using existing Flutter iOS artifacts")
    else
      if File.exist?(dart_defines_file)
        UI.message("Using dart_defines.env for build configuration")
        sh("cd .. && #{flutter_build_env_prefix} flutter build ios --release --no-codesign --target lib/main.dart --dart-define-from-file=#{dart_defines_file.shellescape}")
      elsif !ENV["SUPABASE_URL"].to_s.empty? && !ENV["SUPABASE_ANON_KEY"].to_s.empty?
        supabase_url = ENV["SUPABASE_URL"]
        supabase_anon_key = ENV["SUPABASE_ANON_KEY"]
        app_url = ENV["APP_URL"] || "https://app.iworkr.com"
        UI.message("Using env vars for build configuration (SUPABASE_URL set)")
        sh("cd .. && #{flutter_build_env_prefix} flutter build ios --release --no-codesign --target lib/main.dart --dart-define=SUPABASE_URL=#{supabase_url.shellescape} --dart-define=SUPABASE_ANON_KEY=#{supabase_anon_key.shellescape} --dart-define=APP_URL=#{app_url.shellescape}")
      else
        UI.important("No dart_defines.env or env vars found — building with production defaults baked into supabase_service.dart")
        sh("cd .. && #{flutter_build_env_prefix} flutter build ios --release --no-codesign --target lib/main.dart")
      end
    end

    # 3. Increment build number (auto-increment based on latest TestFlight build)
    latest = begin
      latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "com.iworkr.app"
      )
    rescue => e
      UI.important("Could not fetch latest build number: #{e.message}")
      UI.important("Using build number 1 (run setup_app first if the app does not exist)")
      0
    end
    increment_build_number(
      build_number: latest + 1,
      xcodeproj: "Runner.xcodeproj"
    )

    # 4. Write the API key to a temporary .p8 file for Xcode signing
    require "base64"
    api_key_path = File.join(Dir.tmpdir, "AuthKey_#{ENV['ASC_KEY_ID']}.p8")
    File.write(api_key_path, Base64.decode64(ENV["ASC_KEY_CONTENT"]))

    # 5. Build the signed IPA with automatic signing via ASC API key
    #    -allowProvisioningUpdates + -authenticationKey* lets Xcode
    #    auto-manage certificates and profiles for all targets.
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "iWorkr.ipa",
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath '#{api_key_path}' -authenticationKeyID '#{ENV['ASC_KEY_ID']}' -authenticationKeyIssuerID '#{ENV['ASC_ISSUER_ID']}'"
    )

    # 6. Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: false
    )

    UI.success("iWorkr uploaded to TestFlight!")
  end

  # ──────────────────────────────────────────────────────────────────
  # Lane: build_only
  # Builds the IPA without uploading. Useful for local testing.
  # Usage: fastlane ios build_only
  # ──────────────────────────────────────────────────────────────────
  desc "Build IPA without uploading"
  lane :build_only do
    dart_defines_file = File.expand_path("../../dart_defines.env", __dir__)
    flutter_build_env_prefix = "env -u BUNDLE_GEMFILE -u BUNDLE_BIN_PATH -u RUBYOPT -u RUBYLIB"
    if File.exist?(dart_defines_file)
      sh("cd .. && #{flutter_build_env_prefix} flutter build ios --release --no-codesign --target lib/main.dart --dart-define-from-file=#{dart_defines_file.shellescape}")
    else
      sh("cd .. && #{flutter_build_env_prefix} flutter build ios --release --no-codesign --target lib/main.dart")
    end

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "iWorkr.ipa",
      xcargs: "-allowProvisioningUpdates"
    )
  end
end
