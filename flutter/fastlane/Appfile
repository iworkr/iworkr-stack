apple_id(ENV['APPLE_ID'] || 'charlie@iworkr.com')
team_id(ENV['APPLE_TEAM_ID'] || '7S2XCJ2V5F')
itc_team_id(ENV['ITC_TEAM_ID'] || '7S2XCJ2V5F')

for_platform :android do
  json_key_file(ENV['GOOGLE_PLAY_JSON_KEY_PATH'] || 'fastlane/google-play-key.json')
  package_name(ENV['BUNDLE_ID'] || 'com.iworkr.app')
end
